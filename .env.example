# NOTIFIER_NTFY_TOPIC=my-digest

# Telegram
# NOTIFIER_TYPE=telegram
# NOTIFIER_TELEGRAM_BOT_TOKEN=
# NOTIFIER_TELEGRAM_CHAT_ID=

# Schedule
# SCHEDULE_TIME=08:00
# SCHEDULE_TIMEZONE=UTC
